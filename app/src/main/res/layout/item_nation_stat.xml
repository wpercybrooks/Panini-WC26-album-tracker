<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/nationName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="Colombia" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/nationProgressText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            tools:text="15/20 (75%)" />

        <TextView
            android:id="@+id/nationDuplicatesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/duplicate_orange"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="5 duplicates" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/nationProgressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="4dp"
        android:progressDrawable="@drawable/circle_bg"
        tools:progress="75" />
</LinearLayout>